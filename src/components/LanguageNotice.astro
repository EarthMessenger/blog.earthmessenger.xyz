---
const { from, to, displayLang } = Astro.props;
import ColorfulBlockquote from './ColorfulBlockquote.astro';

import { useTranslations } from '../i18n.js';

const t = useTranslations(displayLang);

const notice = t('language-notice', {
  from: t(from),
  to: t(to),
});
---

{
  (
    <ColorfulBlockquote color="blue">
      <p set:html={notice} />
    </ColorfulBlockquote>
  )
}

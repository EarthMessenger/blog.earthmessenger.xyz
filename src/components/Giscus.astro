---
const path = Astro.url.pathname.replace(/^\/(zh-hans|zh-hant)\//, "/").slice(1);
const lang = Astro.url.pathname.startsWith("/zh-hans/") ? "zh-CN" : "zh-TW";
---

<script is:inline src="https://giscus.app/client.js"
        data-repo="earthmessenger/blog.earthmessenger.xyz"
        data-repo-id="MDEwOlJlcG9zaXRvcnkzODc0MzYzNTQ="
        data-category="giscus"
        data-category-id="DIC_kwDOFxfPQs4CAtxr"
        data-mapping="specific"
        data-term={path}
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="gruvbox"
        data-lang={lang}
        crossorigin="anonymous"
        async>
</script>
